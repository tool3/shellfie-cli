
# Where should we write the SVG?
Output test.svg

# Set up a 1200x600 terminal with 46px font.
Set FontSize 12
Set Width 600
Set Height 600
Set TypingSpeed 50

# Type a command in the terminal.
Type "npm test"

# Pause for dramatic effect...
Sleep 500ms

# Run the command by pressing enter.
Enter

Sleep 1000ms