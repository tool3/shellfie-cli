# Rainbow Text Demo
# Beautiful gradient color effect in terminal

Output examples/dvds/rainbow.svg

Set Width 1000
Set Height 400
Set FontSize 18
Set Title "Rainbow Colors"
Set PromptPrefix "\x1b[95m✨\x1b[0m "

Type "echo '\x1b[91m█\x1b[93m█\x1b[92m█\x1b[96m█\x1b[94m█\x1b[95m█\x1b[0m Rainbow!'"
Sleep 600ms
Enter
Sleep 2s

Type "echo '\x1b[1;31mB\x1b[1;33me\x1b[1;32ma\x1b[1;36mu\x1b[1;34mt\x1b[1;35mi\x1b[1;31mf\x1b[1;33mu\x1b[1;32ml\x1b[0m'"
Sleep 600ms
Enter
Sleep 3s
