{
  "name": "shellfie-cli",
  "version": "2.3.0",
  "description": "Terminal output to beautiful SVGs",
  "bin": {
    "shellfie": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "terminal",
    "svg",
    "screenshot",
    "ansi",
    "cli",
    "shellfie",
    "tty",
    "carbon",
    "terminal-screenshot"
  ],
  "author": "tool3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tool3/shellfie-cli"
  },
  "dependencies": {
    "shellfie": "^2.3.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/yargs": "^17.0.32",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
